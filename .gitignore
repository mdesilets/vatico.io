# ============================================================
# Vatico — workspace gitignore
# Keep working artifacts on disk locally, off the deploy/repo.
# ============================================================

# --- OS / editor ---
.DS_Store
Thumbs.db
*.swp
*.swo
.vscode/
.idea/

# --- Cursor / SpecStory transcript scratch (already untracked) ---
.specstory/

# --- Original archive bundles ---
*.zip

# --- Internal strategy / brand-voice documents ---
capabilities-deck.md
positioning-playbook.md

# --- Files in the deploy tree the live page does not reference ---
# CSS / JS that index.html does not <link>/<script>:
colors_and_type_standalone.css
footprint.js

# Design-iteration screenshots and pasted reference PNGs
# (Phase B.1 will delete these from disk; ignored here so they
# never accidentally get committed in the meantime.)
screenshots/
uploads/

# --- Local screenshot scratch from MCP tooling ---
hero-*.png
hero-*.jpg
*-screenshot-*.png

# --- Asset-pack working tree (out of deploy) ---
asset-pack/

# --- Website-v2 source bundle (reference only) ---
website-v2/

# --- Node / build (in case anything is added later) ---
node_modules/
dist/
.wrangler/
.dev.vars
.env
.env.local
